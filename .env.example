# Project Configuration
PROJECT_NAME=Wahlsystem

# =============================================================================
# Development Environment
# =============================================================================

# Nginx Ports
NGINX_PORT=80

# Frontend (Vite dev server - works with Vue, React, Svelte)
FRONTEND_PORT=5173

# Backend (Spring Boot)
BACKEND_PORT=8080
DEBUG_PORT=5005

# Database (MariaDB - Default)
DB_PORT=3306
DB_NAME=myapp_db
DB_USER=myapp_user
DB_PASSWORD=change_me_in_production
DB_ROOT_PASSWORD=change_me_root_password

# phpMyAdmin (for MariaDB)
PHPMYADMIN_PORT=8081

# Alternative: PostgreSQL (commented out - uncomment to use instead of MariaDB)
# DB_PORT=5432
# PGADMIN_PORT=5050
# PGADMIN_EMAIL=admin@example.com
# PGADMIN_PASSWORD=change_me_admin

# Redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis

# Redis Commander (Redis GUI)
REDIS_COMMANDER_PORT=8082

# =============================================================================
# Production Environment
# =============================================================================

# Nginx Ports
NGINX_SSL_PORT=443

# Production phpMyAdmin (optional, usually disabled or VPN-restricted)
# PHPMYADMIN_PORT=8081
