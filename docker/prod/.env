# Production Environment Configuration
# WARNING: Change all default passwords before deploying!

PROJECT_NAME=Wahlsystem

# Nginx
NGINX_PORT=80
NGINX_SSL_PORT=443

# MariaDB Database (Default)
DB_NAME=myapp_db
DB_USER=myapp_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_ROOT_PASSWORD=CHANGE_ME_STRONG_ROOT_PASSWORD

# Redis
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# Optional: phpMyAdmin (usually disabled in production)
# PHPMYADMIN_PORT=8081

# JWT
JWT_SECRET=CHANGE_ME_STRONG_JWT_SECRET_MIN_32_CHARS

# Password hashing
PASSWORD_ALGORITHM=argon2
PASSWORD_BCRYPT_STRENGTH=12
# REQUIRED: Set a strong random pepper. Never share or commit this value.
# Generate one with: openssl rand -base64 32
PASSWORD_PEPPER=CHANGE_ME_STRONG_RANDOM_PEPPER
