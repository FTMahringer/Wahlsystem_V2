# Production Environment Configuration
# WARNING: Change all default passwords before deploying!

PROJECT_NAME=myapp

# Nginx
NGINX_PORT=80
NGINX_SSL_PORT=443

# MariaDB Database (Default)
DB_NAME=myapp_db
DB_USER=myapp_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_ROOT_PASSWORD=CHANGE_ME_STRONG_ROOT_PASSWORD

# Redis
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# Optional: phpMyAdmin (usually disabled in production)
# PHPMYADMIN_PORT=8081
