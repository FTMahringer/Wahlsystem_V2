# Development Environment Configuration
# Copy from .env.example and modify as needed

PROJECT_NAME=Wahlsystem

# Frontend (Vite dev server - works with Vue 3.5.31+, React, Svelte)
FRONTEND_PORT=5173

# Backend (Spring Boot with Java 26)
BACKEND_PORT=8080
DEBUG_PORT=5005

# MariaDB Database (Default)
DB_PORT=3306
DB_NAME=myapp_db
DB_USER=myapp_user
DB_PASSWORD=dev_password_123
DB_ROOT_PASSWORD=dev_root_password_123

# phpMyAdmin
PHPMYADMIN_PORT=8081

# Redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_dev_password

# Redis Commander
REDIS_COMMANDER_PORT=8082

# JWT
JWT_SECRET=ZGV2LW9ubHktand0LXNlY3JldC1rZXktZm9yLXdhaGxzeXN0ZW0tYXBwbGljYXRpb24tbm90LWZvci1wcm9kdWN0aW9uLXVzZQ==

# Password hashing
# Algorithm: bcrypt | argon2 | scrypt
PASSWORD_ALGORITHM=bcrypt
# Pepper: server-side secret mixed into every password hash via HMAC-SHA256.
# Change this to a strong random value and never commit it to source control.
# Changing it will invalidate all existing password hashes.
PASSWORD_PEPPER=dev-pepper
