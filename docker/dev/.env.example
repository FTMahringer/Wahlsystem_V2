# Development Environment Configuration
# Copy from .env.example and modify as needed

PROJECT_NAME=myapp

# Frontend (Vite dev server - works with Vue 3.5.31+, React, Svelte)
FRONTEND_PORT=5173

# Backend (Spring Boot with Java 26)
BACKEND_PORT=8080
DEBUG_PORT=5005

# MariaDB Database (Default)
DB_PORT=3306
DB_NAME=myapp_db
DB_USER=myapp_user
DB_PASSWORD=change_me_password
DB_ROOT_PASSWORD=change_me_root_password

# phpMyAdmin
PHPMYADMIN_PORT=8081

# Redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password

# Redis Commander
REDIS_COMMANDER_PORT=8082
