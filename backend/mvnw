#!/bin/sh
# Apache Maven Wrapper startup script
# -----------------------------------------------------------------------------

APP_HOME=$( cd "${APP_HOME:-.}" && pwd -P ) || exit
CLASSPATH=$APP_HOME/.mvn/wrapper/maven-wrapper.jar

# Determine the Java command to use to start the JVM.
if [ -n "$JAVA_HOME" ] ; then
    if [ -x "$JAVA_HOME/jre/sh/java" ] ; then
        JAVACMD="$JAVA_HOME/jre/sh/java"
    else
        JAVACMD="$JAVA_HOME/bin/java"
    fi
    if [ ! -x "$JAVACMD" ] ; then
        echo "ERROR: JAVA_HOME is set to an invalid directory: $JAVA_HOME"
        exit 1
    fi
else
    JAVACMD="java"
    if ! command -v java >/dev/null 2>&1 ; then
        echo "ERROR: JAVA_HOME is not set and no 'java' command could be found"
        exit 1
    fi
fi

exec "$JAVACMD" $MAVEN_OPTS $MAVEN_DEBUG_OPTS -classpath "$CLASSPATH" -Dmaven.multiModuleProjectDirectory="$MAVEN_PROJECTBASEDIR" org.apache.maven.wrapper.MavenWrapperMain "$@"
